{
  "mcpServers": {
    "kolide": {
      "command": "uv",
      "args": [
        "--directory",
        "/absolute/path/to/device-trust-mcp-server",
        "run",
        "kolide-mcp-stdio"
      ],
      "env": {
        "KOLIDE_API_KEY": "your-kolide-api-key",
        "KOLIDE_API_VERSION": "2026-04-07"
      }
    }
  }
}
